+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#include "nr-mac-scheduler-ofdma-aoi.h"
+
+#include "nr-mac-scheduler-ue-info-aoi.h"
+
+#include <ns3/double.h>
+#include <ns3/log.h>
+
+namespace ns3
+{
+
+NS_LOG_COMPONENT_DEFINE("NrMacSchedulerOfdmaAoi");
+NS_OBJECT_ENSURE_REGISTERED(NrMacSchedulerOfdmaAoi);
+
+TypeId
+NrMacSchedulerOfdmaAoi::GetTypeId()
+{
+    static TypeId tid =
+        TypeId("ns3::NrMacSchedulerOfdmaAoi")
+            .SetParent<NrMacSchedulerOfdmaEdf>()
+            .AddConstructor<NrMacSchedulerOfdmaAoi>()
+            .AddAttribute(
+                "AoIBeta",
+                "Weight of the AoI additive term in the DL scheduling metric. "
+                "weight = urgency × (AoIBeta × age_ms + PF). "
+                "Set to 0 to disable AoI awareness (degenerates to EDF).",
+                DoubleValue(0.01),
+                MakeDoubleAccessor(&NrMacSchedulerOfdmaAoi::SetAoiBeta,
+                                   &NrMacSchedulerOfdmaAoi::GetAoiBeta),
+                MakeDoubleChecker<double>(0.0));
+    return tid;
+}
+
+NrMacSchedulerOfdmaAoi::NrMacSchedulerOfdmaAoi()
+    : NrMacSchedulerOfdmaEdf()
+{
+}
+
+void
+NrMacSchedulerOfdmaAoi::SetAoiBeta(double v)
+{
+    NS_LOG_FUNCTION(this << v);
+    m_aoiBeta = v;
+}
+
+double
+NrMacSchedulerOfdmaAoi::GetAoiBeta() const
+{
+    return m_aoiBeta;
+}
+
+std::shared_ptr<NrMacSchedulerUeInfo>
+NrMacSchedulerOfdmaAoi::CreateUeRepresentation(
+    const NrMacCschedSapProvider::CschedUeConfigReqParameters& params) const
+{
+    NS_LOG_FUNCTION(this);
+    return std::make_shared<NrMacSchedulerUeInfoAoi>(
+        static_cast<float>(m_alpha),
+        m_aoiBeta,
+        params.m_rnti,
+        params.m_beamConfId,
+        std::bind(&NrMacSchedulerOfdmaAoi::GetNumRbPerRbg, this));
+}
+
+std::function<bool(const NrMacSchedulerNs3::UePtrAndBufferReq&,
+                   const NrMacSchedulerNs3::UePtrAndBufferReq&)>
+NrMacSchedulerOfdmaAoi::GetUeCompareDlFn() const
+{
+    return NrMacSchedulerUeInfoAoi::CompareUeWeightsDl;
+}
+
+void
+NrMacSchedulerOfdmaAoi::AssignedDlResources(const UePtrAndBufferReq& ue,
+                                            [[maybe_unused]] const FTResources& assigned,
+                                            const FTResources& totAssigned) const
+{
+    NS_LOG_FUNCTION(this);
+    auto uePtr = std::dynamic_pointer_cast<NrMacSchedulerUeInfoAoi>(ue.first);
+    // Record transmission time — resets the AoI clock for this UE.
+    uePtr->OnDlTransmission();
+    // Also update EDF throughput bookkeeping (inherited).
+    uePtr->UpdateDlEdfMetric(totAssigned, m_timeWindow, m_dlAmc);
+}
+
+void
+NrMacSchedulerOfdmaAoi::NotAssignedDlResources(const UePtrAndBufferReq& ue,
+                                               [[maybe_unused]] const FTResources& notAssigned,
+                                               const FTResources& totalAssigned) const
+{
+    NS_LOG_FUNCTION(this);
+    // UE was not served this TTI — AoI keeps growing (no reset needed).
+    auto uePtr = std::dynamic_pointer_cast<NrMacSchedulerUeInfoAoi>(ue.first);
+    uePtr->UpdateDlEdfMetric(totalAssigned, m_timeWindow, m_dlAmc);
+}
+
+} // namespace ns3
