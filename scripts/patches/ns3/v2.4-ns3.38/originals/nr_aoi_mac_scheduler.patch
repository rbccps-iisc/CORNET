diff --git a/model/nr-mac-scheduler-ue-info-aoi.h b/model/nr-mac-scheduler-ue-info-aoi.h
new file mode 100644
index 00000000..41ca1269
--- /dev/null
+++ b/model/nr-mac-scheduler-ue-info-aoi.h
@@ -0,0 +1,133 @@
+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#pragma once
+
+#include "nr-mac-scheduler-ue-info-edf.h"
+
+#include <ns3/simulator.h>
+
+#include <cmath>
+
+namespace ns3
+{
+
+/**
+ * \ingroup scheduler
+ * \brief Per-UE state for the AoI-aware proportional-fair MAC scheduler.
+ *
+ * Extends NrMacSchedulerUeInfoEdf with an Age-of-Information (AoI) term that
+ * is blended into the DL scheduling weight:
+ *
+ *   weight = max(urgency, ε) × (aoi_factor + PF_factor)
+ *
+ * where:
+ *   urgency      = EDF deadline/reliability term (inherited)
+ *   aoi_factor   = m_aoiBeta × (Simulator::Now() - m_lastTxTime) in ms
+ *   PF_factor    = potentialTput^α / avgTput
+ *
+ * When m_aoiBeta = 0 the scheduler degenerates to EDF.
+ * Default m_aoiBeta = 0.01 gives an AoI contribution of ~1 per 100 ms of
+ * inactivity, which is clearly distinguishable from the PF term at 8-20 ms
+ * link delays.
+ *
+ * The UL comparator is inherited unchanged from NrMacSchedulerUeInfoEdf.
+ */
+class NrMacSchedulerUeInfoAoi : public NrMacSchedulerUeInfoEdf
+{
+  public:
+    NrMacSchedulerUeInfoAoi(float alpha,
+                            double aoiBeta,
+                            uint16_t rnti,
+                            BeamConfId beamConfId,
+                            const GetRbPerRbgFn& fn)
+        : NrMacSchedulerUeInfoEdf(alpha, rnti, beamConfId, fn),
+          m_aoiBeta(aoiBeta)
+    {
+    }
+
+    /**
+     * \brief Call after a successful DL transmission to record the TX time
+     *        and reset the AoI accumulator.
+     */
+    void OnDlTransmission()
+    {
+        m_lastTxTime = Simulator::Now();
+        m_aoiMs = 0.0;
+    }
+
+    /**
+     * \brief Return the current AoI for this UE in milliseconds.
+     *
+     * This is the time elapsed since the last successful DL transmission.
+     * If the UE has never been scheduled m_lastTxTime is zero and we return
+     * the simulation time as the AoI (i.e. the UE has been waiting since
+     * the beginning).
+     */
+    double GetAoiMs() const
+    {
+        return (Simulator::Now() - m_lastTxTime).GetMilliSeconds();
+    }
+
+    // ----------------------------------------------------------------
+    //  DL weight — AoI-PF hybrid
+    // ----------------------------------------------------------------
+
+    static bool CompareUeWeightsDl(const NrMacSchedulerNs3::UePtrAndBufferReq& lue,
+                                   const NrMacSchedulerNs3::UePtrAndBufferReq& rue)
+    {
+        return CalculateDlWeightAoi(lue) > CalculateDlWeightAoi(rue);
+    }
+
+    static double CalculateDlWeightAoi(const NrMacSchedulerNs3::UePtrAndBufferReq& ue)
+    {
+        auto uePtr = dynamic_cast<NrMacSchedulerUeInfoAoi*>(ue.first.get());
+
+        // --- EDF urgency term (inherited logic, inlined) ---
+        double urgencyWeight = 0.0;
+        for (const auto& ueLcg : ue.first->m_dlLCG)
+        {
+            std::vector<uint8_t> lcIds = ueLcg.second->GetLCId();
+            for (const auto lcId : lcIds)
+            {
+                const NrMacSchedulerLC* lc = ueLcg.second->GetLC(lcId);
+                if (lc == nullptr || lc->GetTotalSize() == 0)
+                {
+                    continue;
+                }
+                const double delayBudgetMs =
+                    static_cast<double>(lc->m_delayBudget.GetMilliSeconds());
+                const double holDelayMs =
+                    static_cast<double>(lc->m_rlcTransmissionQueueHolDelay);
+                const double remainingBudget = std::max(0.1, delayBudgetMs - holDelayMs);
+                const double delayUrgency =
+                    delayBudgetMs > 0.0 ? (delayBudgetMs / remainingBudget)
+                                        : (1.0 / remainingBudget);
+                urgencyWeight += delayUrgency * (1.0 / std::max(1E-9, lc->m_PER));
+            }
+        }
+
+        // --- AoI additive term: β × age_ms ---
+        const double aoiMs = uePtr->GetAoiMs();
+        const double aoiFactor = uePtr->m_aoiBeta * aoiMs;
+
+        // --- PF multiplicative term ---
+        const double pfFactor =
+            std::pow(std::max(1E-9, uePtr->m_potentialTputDl), uePtr->m_alpha) /
+            std::max(1E-9, uePtr->m_avgTputDl);
+
+        // Weight = urgency × (AoI_boost + PF)
+        return std::max(1E-9, urgencyWeight) * (aoiFactor + std::max(1.0, pfFactor));
+    }
+
+    // ----------------------------------------------------------------
+    //  State
+    // ----------------------------------------------------------------
+    Time   m_lastTxTime{};      ///< Simulation time of last DL frame assignment
+    double m_aoiMs{0.0};        ///< Cached AoI in ms (informational; GetAoiMs() is live)
+    double m_aoiBeta{0.01};     ///< AoI weight coefficient
+};
+
+} // namespace ns3
