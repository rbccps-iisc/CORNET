+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:null; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#pragma once
+
+#include "nr-mac-scheduler-ofdma-edf.h"
+
+namespace ns3
+{
+
+/**
+ * \ingroup scheduler
+ * \brief 5G NR MAC OFDMA scheduler with Age-of-Information (AoI) awareness.
+ *
+ * Extends NrMacSchedulerOfdmaEdf with an additive AoI term in the DL
+ * scheduling weight.  The priority metric for UE selection is:
+ *
+ *   weight = urgency × (β·AoI_ms + PF)
+ *
+ * where:
+ *   urgency = EDF deadline/reliability ratio (see NrMacSchedulerUeInfoEdf)
+ *   AoI_ms  = milliseconds since this UE last received a DL allocation
+ *   β       = AoIBeta attribute (default 0.01)
+ *   PF      = potentialTput^alpha / avgTput  (Proportional-Fair term)
+ *
+ * Attributes (in addition to those from NrMacSchedulerOfdmaEdf):
+ *   - AoIBeta: weight of the AoI additive contribution (default 0.01)
+ *
+ * Usage in ns-3 scenario:
+ *   nrHelper->SetSchedulerTypeId(NrMacSchedulerOfdmaAoi::GetTypeId());
+ *   nrHelper->SetSchedulerAttribute("AoIBeta", DoubleValue(0.01));
+ */
+class NrMacSchedulerOfdmaAoi : public NrMacSchedulerOfdmaEdf
+{
+  public:
+    static TypeId GetTypeId();
+
+    NrMacSchedulerOfdmaAoi();
+
+    void SetAoiBeta(double v);
+    double GetAoiBeta() const;
+
+  protected:
+    std::shared_ptr<NrMacSchedulerUeInfo> CreateUeRepresentation(
+        const NrMacCschedSapProvider::CschedUeConfigReqParameters& params) const override;
+
+    std::function<bool(const NrMacSchedulerNs3::UePtrAndBufferReq&,
+                       const NrMacSchedulerNs3::UePtrAndBufferReq&)>
+    GetUeCompareDlFn() const override;
+
+    // Override AssignedDlResources to update the AoI timestamp on TX
+    void AssignedDlResources(const UePtrAndBufferReq& ue,
+                             const FTResources& assigned,
+                             const FTResources& totAssigned) const override;
+
+    void NotAssignedDlResources(const UePtrAndBufferReq& ue,
+                                const FTResources& notAssigned,
+                                const FTResources& totAssigned) const override;
+
+  private:
+    double m_aoiBeta{0.01};
+};
+
+} // namespace ns3
