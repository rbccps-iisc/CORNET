+++ b/model/nr-mac-scheduler-ue-info-edf.h	2026-03-19 15:08:52.665489063 +0530
@@ -0,0 +1,143 @@
+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#pragma once
+
+#include "nr-mac-scheduler-ue-info-rr.h"
+
+#include <cmath>
+
+namespace ns3
+{
+
+/**
+ * \ingroup scheduler
+ * \brief UE representation for EDF-style scheduling.
+ *
+ * The implementation keeps the PF-style throughput bookkeeping already used by
+ * the NR schedulers, but the DL ordering is driven by urgency derived from the
+ * remaining packet delay budget and the bearer PER target.
+ */
+class NrMacSchedulerUeInfoEdf : public NrMacSchedulerUeInfo
+{
+  public:
+    NrMacSchedulerUeInfoEdf(float alpha,
+                            uint16_t rnti,
+                            BeamConfId beamConfId,
+                            const GetRbPerRbgFn& fn)
+        : NrMacSchedulerUeInfo(rnti, beamConfId, fn),
+          m_alpha(alpha)
+    {
+    }
+
+    void ResetDlSchedInfo() override
+    {
+        m_lastAvgTputDl = m_avgTputDl;
+        m_avgTputDl = 0.0;
+        m_currTputDl = 0.0;
+        m_potentialTputDl = 0.0;
+        NrMacSchedulerUeInfo::ResetDlSchedInfo();
+    }
+
+    void ResetUlSchedInfo() override
+    {
+        m_lastAvgTputUl = m_avgTputUl;
+        m_avgTputUl = 0.0;
+        m_currTputUl = 0.0;
+        m_potentialTputUl = 0.0;
+        NrMacSchedulerUeInfo::ResetUlSchedInfo();
+    }
+
+    void ResetDlMetric() override
+    {
+        NrMacSchedulerUeInfo::ResetDlMetric();
+        m_avgTputDl = m_lastAvgTputDl;
+    }
+
+    void ResetUlMetric() override
+    {
+        NrMacSchedulerUeInfo::ResetUlMetric();
+        m_avgTputUl = m_lastAvgTputUl;
+    }
+
+    void UpdateDlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                           double timeWindow,
+                           const Ptr<const NrAmc>& amc);
+
+    void UpdateUlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                           double timeWindow,
+                           const Ptr<const NrAmc>& amc);
+
+    void CalculatePotentialTPutDl(const NrMacSchedulerNs3::FTResources& assignableInIteration,
+                                  const Ptr<const NrAmc>& amc);
+
+    void CalculatePotentialTPutUl(const NrMacSchedulerNs3::FTResources& assignableInIteration,
+                                  const Ptr<const NrAmc>& amc);
+
+    static bool CompareUeWeightsDl(const NrMacSchedulerNs3::UePtrAndBufferReq& lue,
+                                   const NrMacSchedulerNs3::UePtrAndBufferReq& rue)
+    {
+        double lWeight = CalculateDlWeight(lue);
+        double rWeight = CalculateDlWeight(rue);
+        return lWeight > rWeight;
+    }
+
+    static bool CompareUeWeightsUl(const NrMacSchedulerNs3::UePtrAndBufferReq& lue,
+                                   const NrMacSchedulerNs3::UePtrAndBufferReq& rue)
+    {
+        auto luePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(lue.first.get());
+        auto ruePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(rue.first.get());
+
+        double lMetric = std::pow(luePtr->m_potentialTputUl, luePtr->m_alpha) /
+                         std::max(1E-9, luePtr->m_avgTputUl);
+        double rMetric = std::pow(ruePtr->m_potentialTputUl, ruePtr->m_alpha) /
+                         std::max(1E-9, ruePtr->m_avgTputUl);
+        return lMetric > rMetric;
+    }
+
+    static double CalculateDlWeight(const NrMacSchedulerNs3::UePtrAndBufferReq& ue)
+    {
+        auto uePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(ue.first.get());
+        double urgencyWeight = 0.0;
+
+        for (const auto& ueLcg : ue.first->m_dlLCG)
+        {
+            std::vector<uint8_t> lcIds = ueLcg.second->GetLCId();
+            for (const auto lcId : lcIds)
+            {
+                const NrMacSchedulerLC* lc = ueLcg.second->GetLC(lcId);
+                if (lc == nullptr || lc->GetTotalSize() == 0)
+                {
+                    continue;
+                }
+
+                const double delayBudgetMs = static_cast<double>(lc->m_delayBudget.GetMilliSeconds());
+                const double holDelayMs = static_cast<double>(lc->m_rlcTransmissionQueueHolDelay);
+                const double remainingBudgetMs = std::max(0.1, delayBudgetMs - holDelayMs);
+                const double delayUrgency = delayBudgetMs > 0.0 ? (delayBudgetMs / remainingBudgetMs)
+                                                                : (1.0 / remainingBudgetMs);
+                const double reliabilityWeight = 1.0 / std::max(1E-9, lc->m_PER);
+                urgencyWeight += delayUrgency * reliabilityWeight;
+            }
+        }
+
+        const double pfMetric = std::pow(std::max(1E-9, uePtr->m_potentialTputDl), uePtr->m_alpha) /
+                                std::max(1E-9, uePtr->m_avgTputDl);
+        return std::max(1E-9, urgencyWeight) * std::max(1.0, pfMetric);
+    }
+
+    double m_currTputDl{0.0};
+    double m_avgTputDl{0.0};
+    double m_lastAvgTputDl{0.0};
+    double m_potentialTputDl{0.0};
+    float m_alpha{0.0};
+
+    double m_currTputUl{0.0};
+    double m_avgTputUl{0.0};
+    double m_lastAvgTputUl{0.0};
+    double m_potentialTputUl{0.0};
+};
+
+} // namespace ns3
