+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#pragma once
+
+#include "nr-mac-scheduler-ofdma-rr.h"
+
+namespace ns3
+{
+
+/**
+ * \ingroup scheduler
+ * \brief Assign frequencies in an EDF-inspired fashion.
+ *
+ * DL UE ordering is based on remaining delay budget and bearer PER, while UL
+ * keeps the existing throughput-aware ordering.
+ */
+class NrMacSchedulerOfdmaEdf : public NrMacSchedulerOfdmaRR
+{
+  public:
+    static TypeId GetTypeId();
+
+    NrMacSchedulerOfdmaEdf();
+
+    ~NrMacSchedulerOfdmaEdf() override
+    {
+    }
+
+    void SetFairnessIndex(double v);
+    double GetFairnessIndex() const;
+
+    void SetTimeWindow(double v);
+    double GetTimeWindow() const;
+
+  protected:
+    std::shared_ptr<NrMacSchedulerUeInfo> CreateUeRepresentation(
+        const NrMacCschedSapProvider::CschedUeConfigReqParameters& params) const override;
+
+    std::function<bool(const NrMacSchedulerNs3::UePtrAndBufferReq& lhs,
+                       const NrMacSchedulerNs3::UePtrAndBufferReq& rhs)>
+    GetUeCompareDlFn() const override;
+
+    std::function<bool(const NrMacSchedulerNs3::UePtrAndBufferReq& lhs,
+                       const NrMacSchedulerNs3::UePtrAndBufferReq& rhs)>
+    GetUeCompareUlFn() const override;
+
+    void AssignedDlResources(const UePtrAndBufferReq& ue,
+                             const FTResources& assigned,
+                             const FTResources& totAssigned) const override;
+
+    void NotAssignedDlResources(const UePtrAndBufferReq& ue,
+                                const FTResources& notAssigned,
+                                const FTResources& totalAssigned) const override;
+
+    void AssignedUlResources(const UePtrAndBufferReq& ue,
+                             const FTResources& assigned,
+                             const FTResources& totAssigned) const override;
+
+    void NotAssignedUlResources(const UePtrAndBufferReq& ue,
+                                const FTResources& notAssigned,
+                                const FTResources& totalAssigned) const override;
+
+    void BeforeDlSched(const UePtrAndBufferReq& ue,
+                       const FTResources& assignableInIteration) const override;
+
+    void BeforeUlSched(const UePtrAndBufferReq& ue,
+                       const FTResources& assignableInIteration) const override;
+
+  protected:
+    double m_timeWindow{99.0};
+    double m_alpha{1.0};
+};
+
+} // namespace ns3
diff --git a/model/nr-mac-scheduler-ue-info-edf.cc b/model/nr-mac-scheduler-ue-info-edf.cc
new file mode 100644
index 00000000..5bbee401
--- /dev/null
+++ b/model/nr-mac-scheduler-ue-info-edf.cc
@@ -0,0 +1,85 @@
+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#include "nr-mac-scheduler-ue-info-edf.h"
+
+#include <ns3/log.h>
+
+namespace ns3
+{
+
+NS_LOG_COMPONENT_DEFINE("NrMacSchedulerUeInfoEdf");
+
+void
+NrMacSchedulerUeInfoEdf::UpdateDlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                                           double timeWindow,
+                                           const Ptr<const NrAmc>& amc)
+{
+    NS_LOG_FUNCTION(this);
+
+    NrMacSchedulerUeInfo::UpdateDlMetric(amc);
+    uint32_t tbSize = 0;
+    for (const auto& it : m_dlTbSize)
+    {
+        tbSize += it;
+    }
+
+    m_currTputDl = static_cast<double>(tbSize) / totAssigned.m_sym;
+    m_avgTputDl = ((1.0 - (1.0 / static_cast<double>(timeWindow))) * m_lastAvgTputDl) +
+                  ((1.0 / timeWindow) * m_currTputDl);
+}
+
+void
+NrMacSchedulerUeInfoEdf::UpdateUlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                                           double timeWindow,
+                                           const Ptr<const NrAmc>& amc)
+{
+    NS_LOG_FUNCTION(this);
+
+    NrMacSchedulerUeInfo::UpdateUlMetric(amc);
+    m_currTputUl = static_cast<double>(m_ulTbSize) / totAssigned.m_sym;
+    m_avgTputUl = ((1.0 - (1.0 / static_cast<double>(timeWindow))) * m_lastAvgTputUl) +
+                  ((1.0 / timeWindow) * m_currTputUl);
+}
+
+void
+NrMacSchedulerUeInfoEdf::CalculatePotentialTPutDl(
+    const NrMacSchedulerNs3::FTResources& assignableInIteration,
+    const Ptr<const NrAmc>& amc)
+{
+    NS_LOG_FUNCTION(this);
+
+    uint32_t rbsAssignable = assignableInIteration.m_rbg * GetNumRbPerRbg();
+    m_potentialTputDl = 0.0;
+
+    if (this->m_dlCqi.m_ri == 1)
+    {
+        auto mcsIt = std::max_element(m_dlMcs.begin(), m_dlMcs.end());
+        m_potentialTputDl = amc->CalculateTbSize(*mcsIt, rbsAssignable);
+    }
+    else if (this->m_dlCqi.m_ri == 2)
+    {
+        for (const auto& it : m_dlMcs)
+        {
+            m_potentialTputDl += amc->CalculateTbSize(it, rbsAssignable);
+        }
+    }
+
+    m_potentialTputDl /= assignableInIteration.m_sym;
+}
+
+void
+NrMacSchedulerUeInfoEdf::CalculatePotentialTPutUl(
+    const NrMacSchedulerNs3::FTResources& assignableInIteration,
+    const Ptr<const NrAmc>& amc)
+{
+    NS_LOG_FUNCTION(this);
+
+    uint32_t rbsAssignable = assignableInIteration.m_rbg * GetNumRbPerRbg();
+    m_potentialTputUl = amc->CalculateTbSize(m_ulMcs, rbsAssignable);
+    m_potentialTputUl /= assignableInIteration.m_sym;
+}
+
+} // namespace ns3
diff --git a/model/nr-mac-scheduler-ue-info-edf.h b/model/nr-mac-scheduler-ue-info-edf.h
new file mode 100644
index 00000000..6de4f230
--- /dev/null
+++ b/model/nr-mac-scheduler-ue-info-edf.h
@@ -0,0 +1,143 @@
+/* -*-  Mode: C++; c-file-style: "gnu"; indent-tabs-mode:nil; -*- */
+
+// Copyright (c) 2026
+// SPDX-License-Identifier: GPL-2.0-only
+
+#pragma once
+
+#include "nr-mac-scheduler-ue-info-rr.h"
+
+#include <cmath>
+
+namespace ns3
+{
+
+/**
+ * \ingroup scheduler
+ * \brief UE representation for EDF-style scheduling.
+ *
+ * The implementation keeps the PF-style throughput bookkeeping already used by
+ * the NR schedulers, but the DL ordering is driven by urgency derived from the
+ * remaining packet delay budget and the bearer PER target.
+ */
+class NrMacSchedulerUeInfoEdf : public NrMacSchedulerUeInfo
+{
+  public:
+    NrMacSchedulerUeInfoEdf(float alpha,
+                            uint16_t rnti,
+                            BeamConfId beamConfId,
+                            const GetRbPerRbgFn& fn)
+        : NrMacSchedulerUeInfo(rnti, beamConfId, fn),
+          m_alpha(alpha)
+    {
+    }
+
+    void ResetDlSchedInfo() override
+    {
+        m_lastAvgTputDl = m_avgTputDl;
+        m_avgTputDl = 0.0;
+        m_currTputDl = 0.0;
+        m_potentialTputDl = 0.0;
+        NrMacSchedulerUeInfo::ResetDlSchedInfo();
+    }
+
+    void ResetUlSchedInfo() override
+    {
+        m_lastAvgTputUl = m_avgTputUl;
+        m_avgTputUl = 0.0;
+        m_currTputUl = 0.0;
+        m_potentialTputUl = 0.0;
+        NrMacSchedulerUeInfo::ResetUlSchedInfo();
+    }
+
+    void ResetDlMetric() override
+    {
+        NrMacSchedulerUeInfo::ResetDlMetric();
+        m_avgTputDl = m_lastAvgTputDl;
+    }
+
+    void ResetUlMetric() override
+    {
+        NrMacSchedulerUeInfo::ResetUlMetric();
+        m_avgTputUl = m_lastAvgTputUl;
+    }
+
+    void UpdateDlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                           double timeWindow,
+                           const Ptr<const NrAmc>& amc);
+
+    void UpdateUlEdfMetric(const NrMacSchedulerNs3::FTResources& totAssigned,
+                           double timeWindow,
+                           const Ptr<const NrAmc>& amc);
+
+    void CalculatePotentialTPutDl(const NrMacSchedulerNs3::FTResources& assignableInIteration,
+                                  const Ptr<const NrAmc>& amc);
+
+    void CalculatePotentialTPutUl(const NrMacSchedulerNs3::FTResources& assignableInIteration,
+                                  const Ptr<const NrAmc>& amc);
+
+    static bool CompareUeWeightsDl(const NrMacSchedulerNs3::UePtrAndBufferReq& lue,
+                                   const NrMacSchedulerNs3::UePtrAndBufferReq& rue)
+    {
+        double lWeight = CalculateDlWeight(lue);
+        double rWeight = CalculateDlWeight(rue);
+        return lWeight > rWeight;
+    }
+
+    static bool CompareUeWeightsUl(const NrMacSchedulerNs3::UePtrAndBufferReq& lue,
+                                   const NrMacSchedulerNs3::UePtrAndBufferReq& rue)
+    {
+        auto luePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(lue.first.get());
+        auto ruePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(rue.first.get());
+
+        double lMetric = std::pow(luePtr->m_potentialTputUl, luePtr->m_alpha) /
+                         std::max(1E-9, luePtr->m_avgTputUl);
+        double rMetric = std::pow(ruePtr->m_potentialTputUl, ruePtr->m_alpha) /
+                         std::max(1E-9, ruePtr->m_avgTputUl);
+        return lMetric > rMetric;
+    }
+
+    static double CalculateDlWeight(const NrMacSchedulerNs3::UePtrAndBufferReq& ue)
+    {
+        auto uePtr = dynamic_cast<NrMacSchedulerUeInfoEdf*>(ue.first.get());
+        double urgencyWeight = 0.0;
+
+        for (const auto& ueLcg : ue.first->m_dlLCG)
+        {
+            std::vector<uint8_t> lcIds = ueLcg.second->GetLCId();
+            for (const auto lcId : lcIds)
+            {
+                const NrMacSchedulerLC* lc = ueLcg.second->GetLC(lcId);
+                if (lc == nullptr || lc->GetTotalSize() == 0)
+                {
+                    continue;
+                }
+
+                const double delayBudgetMs = static_cast<double>(lc->m_delayBudget.GetMilliSeconds());
+                const double holDelayMs = static_cast<double>(lc->m_rlcTransmissionQueueHolDelay);
+                const double remainingBudgetMs = std::max(0.1, delayBudgetMs - holDelayMs);
+                const double delayUrgency = delayBudgetMs > 0.0 ? (delayBudgetMs / remainingBudgetMs)
+                                                                : (1.0 / remainingBudgetMs);
+                const double reliabilityWeight = 1.0 / std::max(1E-9, lc->m_PER);
+                urgencyWeight += delayUrgency * reliabilityWeight;
+            }
+        }
+
+        const double pfMetric = std::pow(std::max(1E-9, uePtr->m_potentialTputDl), uePtr->m_alpha) /
+                                std::max(1E-9, uePtr->m_avgTputDl);
+        return std::max(1E-9, urgencyWeight) * std::max(1.0, pfMetric);
+    }
+
+    double m_currTputDl{0.0};
+    double m_avgTputDl{0.0};
+    double m_lastAvgTputDl{0.0};
+    double m_potentialTputDl{0.0};
+    float m_alpha{0.0};
+
+    double m_currTputUl{0.0};
+    double m_avgTputUl{0.0};
+    double m_lastAvgTputUl{0.0};
+    double m_potentialTputUl{0.0};
+};
+
+} // namespace ns3
diff --git a/model/nr-mac-scheduler-ofdma-aoi.cc b/model/nr-mac-scheduler-ofdma-aoi.cc
