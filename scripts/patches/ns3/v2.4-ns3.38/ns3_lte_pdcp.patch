+    // Duplicate filtering when PDCP repetition is active
+    if (m_numRepetitions > 0)
+    {
+        uint16_t sn = pdcpHeader.GetSequenceNumber();
+        if (m_rxDupSns.count(sn) > 0)
+        {
+            NS_LOG_INFO("PDCP: dropping duplicate PDU, SN=" << sn);
+            return;
+        }
+        m_rxDupSns.insert(sn);
+        // Prune the seen-SN set to prevent unbounded growth
+        if (m_rxDupSns.size() > 64)
+        {
+            m_rxDupSns.clear();
